{
  "name": "change-intelligence",
  "version": "0.1.0",
  "description": "Open-source docs change intelligence for product teams.",
  "type": "module",
  "bin": {
    "change-intel": "./src/cli.js"
  },
  "scripts": {
    "test": "npm run test:node && npm run test:py",
    "test:node": "node --test test/*.test.js",
    "test:py": "python3 -m pytest -q",
    "analyze:fixture": "node ./src/cli.js --diff ./test/fixtures/sample.patch --docs ./test/fixtures/repo/docs --code ./test/fixtures/repo/src",
    "server": "python3 -m change_intelligence.server",
    "server:reference": "node ./src/server.js"
  },
  "keywords": [
    "docs",
    "developer-tools",
    "git",
    "automation",
    "documentation"
  ],
  "license": "MIT"
}
